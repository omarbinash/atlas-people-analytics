# =============================================================================
# Atlas — Environment Configuration
# Copy this file to .env and fill in your real values.
# .env is gitignored — DO NOT COMMIT IT.
# =============================================================================

# Snowflake connection
# -----------------------------------------------------------------------------
# Find your account identifier at https://app.snowflake.com → top-left dropdown
# Format is usually <ORG>-<ACCOUNT>, e.g. ABCDEF-XY12345
SNOWFLAKE_ACCOUNT=YOUR_ACCOUNT_IDENTIFIER

SNOWFLAKE_USER=YOUR_USERNAME
SNOWFLAKE_PASSWORD=YOUR_PASSWORD

# Atlas-specific objects (created by infra/snowflake/*.sql)
SNOWFLAKE_ROLE=ATLAS_DEVELOPER
SNOWFLAKE_WAREHOUSE=ATLAS_WH
SNOWFLAKE_DATABASE=ATLAS
SNOWFLAKE_SCHEMA=RAW

# Region — usually inferred from the account identifier, but set explicitly for some clients
SNOWFLAKE_REGION=us-east-1

# dbt-specific overrides (optional)
# -----------------------------------------------------------------------------
DBT_PROFILES_DIR=./dbt_project
DBT_TARGET=dev
SNOWFLAKE_DBT_SCHEMA=DBT_DEV

# Local development
# -----------------------------------------------------------------------------
# Number of synthetic employees to generate (default 1500 — matches IBM HR Analytics seed)
ATLAS_SYNTHETIC_EMPLOYEE_COUNT=1500
ATLAS_SEED_RANDOM_STATE=42

# API + Dashboard
# -----------------------------------------------------------------------------
ATLAS_API_HOST=127.0.0.1
ATLAS_API_PORT=8000
ATLAS_API_URL=http://127.0.0.1:8000
ATLAS_DASHBOARD_PORT=8501
ATLAS_PEOPLE_ANALYTICS_SCHEMA=DBT_DEV_PEOPLE_ANALYTICS

# Privacy
# -----------------------------------------------------------------------------
# Minimum cohort size for k-anonymity enforcement
ATLAS_K_ANONYMITY_MIN=5
